# Auto-detect text files and normalize to LF in the repo
* text=auto

# Ensure shell scripts use LF
*.sh eol=lf

# Python files explicit
*.py text eol=lf

# Markdown and text
*.md text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.zip binary
*.gz binary

# Node lockfiles should be treated as text
package-lock.json text
pnpm-lock.yaml text
yarn.lock text
