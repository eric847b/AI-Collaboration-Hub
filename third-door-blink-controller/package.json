{
  "name": "blink-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "EXPO_NO_TELEMETRY=1 npx expo start --web --port 3000",
    "start": "EXPO_NO_TELEMETRY=1 npx expo start",
    "start:web": "EXPO_NO_TELEMETRY=1 npx expo start --web",
    "start:ios": "EXPO_NO_TELEMETRY=1 npx expo start --ios",
    "start:android": "EXPO_NO_TELEMETRY=1 npx expo start --android",
    "build:web": "EXPO_NO_TELEMETRY=1 npx expo export --platform web",
    "build:ios": "EXPO_NO_TELEMETRY=1 eas build --platform ios",
    "build:android": "EXPO_NO_TELEMETRY=1 eas build --platform android",
    "eject": "EXPO_NO_TELEMETRY=1 npx expo eject",
    "setup": "EXPO_NO_TELEMETRY=1 npx expo install",
    "install:bun": "bun install",
    "install:fast": "bun install --no-postinstall",
    "add": "bun add",
    "doctor": "EXPO_NO_TELEMETRY=1 npx expo doctor",
    "upgrade": "EXPO_NO_TELEMETRY=1 npx expo upgrade",
    "lint": "EXPO_NO_TELEMETRY=1 npx expo lint",
    "prebuild": "EXPO_NO_TELEMETRY=1 npx expo prebuild",
    "prebuild:clean": "EXPO_NO_TELEMETRY=1 npx expo prebuild --clean"
  },
  "dependencies": {
    "@blinkdotnew/mobile-ui": "2.0.1",
    "@blinkdotnew/sdk": "^2.7.1",
    "@expo/vector-icons": "^15.1.1",
    "@legendapp/list": "^3.3.2",
    "@react-native-async-storage/async-storage": "3.1.1",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~57.0.4",
    "expo-av": "~16.0.8",
    "expo-blur": "~57.0.0",
    "expo-camera": "^57.0.1",
    "expo-constants": "~57.0.3",
    "expo-font": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-picker": "~57.0.2",
    "expo-linear-gradient": "~57.0.0",
    "expo-linking": "~57.0.2",
    "expo-location": "~57.0.2",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-status-bar": "~57.0.0",
    "expo-symbols": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-web-browser": "~57.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~3.0.2",
    "react-native-reanimated": "~4.5.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.26.1",
    "react-native-svg": "15.15.5",
    "react-native-url-polyfill": "^4.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.10.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.17",
    "eslint": "^10.7.0",
    "eslint-config-expo": "~57.0.0",
    "typescript": "~5.9.3"
  }
}
