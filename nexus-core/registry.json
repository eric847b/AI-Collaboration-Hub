{
  "system": "nexus-core",
  "version": "0.3",
  "modules": [
    {
      "name": "autonomous-github-agent",
      "role": "execution"
    },
    {
      "name": "singularity-operator",
      "role": "execution"
    },
    {
      "name": "self-evolve-dash",
      "role": "execution"
    },
    {
      "name": "AI-Collaboration-Hub",
      "role": "coordination"
    },
    {
      "name": "collabhub-modules",
      "role": "coordination"
    },
    {
      "name": "VectorFS",
      "role": "memory"
    },
    {
      "name": "adaptiveos-dashboard",
      "role": "ui"
    },
    {
      "name": "Userscripts",
      "role": "automation"
    },
    {
      "name": "AutoGPT",
